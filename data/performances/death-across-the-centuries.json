          { "kind": "text", "content": "THE SKELETON SURVIVES THE WHOLE JOURNEY —", "start_sec": 34.5, "end_sec": 40.5, "x_pct": 6, "y_pct": 82, "width_pct": 88 },
          { "kind": "text", "content": "RESTAGED AS A RIDER ON A PALE HORSE.", "start_sec": 40.5, "end_sec": 47, "x_pct": 6, "y_pct": 82, "width_pct": 88 }
