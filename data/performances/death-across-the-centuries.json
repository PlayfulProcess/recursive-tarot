          { "kind": "label", "content": "TAROT DE MARSEILLE · 1760", "start_sec": 20.2, "end_sec": 34, "x_pct": 6, "y_pct": 5, "width_pct": 60 },
          { "kind": "text", "content": "THREE CENTURIES ON, THE SAME SKELETON —", "start_sec": 20.5, "end_sec": 26.5, "x_pct": 6, "y_pct": 82, "width_pct": 88 },
          { "kind": "text", "content": "NOW A SCYTHE-MOWER, AND THE CARD UNTITLED.", "start_sec": 26.5, "end_sec": 34, "x_pct": 6, "y_pct": 82, "width_pct": 88 }
        ]
      }
    },
    {
