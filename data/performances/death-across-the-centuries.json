          { "kind": "text", "content": "THE EARLIEST CLEAR TAROT DEATH —", "start_sec": 7.0, "end_sec": 13.0, "x_pct": 6, "y_pct": 82, "width_pct": 88 },
          { "kind": "text", "content": "A WHITE SKELETON ON GOLD, HOLDING A BOW.", "start_sec": 13.0, "end_sec": 20, "x_pct": 6, "y_pct": 82, "width_pct": 88 }
        ]
      }
    },
    {
      "id": "marseille-1760",
      "name": "Death — Tarot de Marseille, 1760",
      "image_url": "https://pub-71ebbc217e6247ecacb85126a6616699.r2.dev/grammar-illustrations/tarot-de-marseille-conver/13%20XIII%20Nicolas%20Conver%20Tarot%201760.jpg",
      "sections": { "Text": "Three centuries on, the same skeleton now mows a field of severed limbs with a scythe — and the card is left pointedly untitled." },
      "metadata": { "deck": "tarot-de-marseille-conver", "trump_key": "death" },
      "performance": {
        "start_sec": 20, "end_sec": 34, "video_visible": false,
